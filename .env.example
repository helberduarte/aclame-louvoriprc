# Copie para .env (uso local) OU cadastre estas variáveis no painel da Vercel
# (Project Settings → Environment Variables). Nunca commite o .env de verdade.

# ---------- PGURL: string de conexão do Supabase ----------
# No painel do Supabase: Project Settings → Database → Connection string → "Transaction pooler".
# Use SEMPRE o pooler em modo transaction (porta 6543) na Vercel — funções serverless
# abrem/fecham conexões o tempo todo, e só o pooler em modo transaction aguenta esse padrão
# sem esgotar o limite de conexões diretas do Postgres do plano gratuito.
PGURL=postgres://postgres.SEU_PROJETO:SUA_SENHA@aws-0-sa-east-1.pooler.supabase.com:6543/postgres

# ---------- Desenvolvimento local (opcional) ----------
# Sem esta variável, o app usa o Postgres local (127.0.0.1:5432, banco "aclame",
# usuário/senha "aclame") — é só o que os testes (`npm test`) sempre usam, independente
# do PGURL acima, para nunca escrever sem querer no banco de produção.
# PGURL=postgres://aclame:aclame@127.0.0.1:5432/aclame

# ---------- Porta do servidor local (ignorado na Vercel) ----------
PORT=3000

# ---------- Cria dados de demonstração se o banco estiver vazio ----------
# Use apenas em ambiente de teste/demo — NUNCA em produção com dados reais.
# ACLAME_SEED=1
